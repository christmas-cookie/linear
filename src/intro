local intro = {}
local fertilizer = loadstring(game:HttpGet("https://raw.githubusercontent.com/christmas-cookie/linear/refs/heads/main/utilities/fertilizer"))()
local ts = game:GetService("TweenService")

function intro:Start()
	local gui = Instance.new("ScreenGui")
	gui.Name = "intro"
	gui.IgnoreGuiInset = true
	gui.DisplayOrder = 9998
	gui.Parent = gethui and gethui() or game:GetService("CoreGui")

	local bg = Instance.new("Frame")
	bg.Name = "bg"
	bg.Size = UDim2.new(1, 0, 1, 0)
	bg.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	bg.BackgroundTransparency = 1
	bg.BorderSizePixel = 0
	bg.ZIndex = 9999
	bg.Parent = gui

	local info = TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In)
	local fadein = ts:Create(bg, info, {BackgroundTransparency = 0})
	fadein:Play()

	repeat task.wait() until bg.BackgroundTransparency <= 0.17

	local startvid = Instance.new("VideoFrame")
	startvid.Name = "start"
	startvid.Size = UDim2.new(0.15, 0, 0.15, 0)
	startvid.Position = UDim2.new(0.5, 0, 0.5, 0)
	startvid.AnchorPoint = Vector2.new(0.5, 0.5)
	startvid.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	startvid.BackgroundTransparency = 0
	startvid.BorderSizePixel = 0
	startvid.ZIndex = 10002
	startvid.Parent = bg

	local c1 = Instance.new("UIAspectRatioConstraint")
	c1.AspectRatio = 1
	c1.Parent = startvid

	local icon = Instance.new("ImageLabel")
	icon.Name = "infinite"
	icon.Size = UDim2.new(0.15, 0, 0.15, 0)
	icon.Position = UDim2.new(0.5, 0, 0.5, 0)
	icon.AnchorPoint = Vector2.new(0.5, 0.5)
	icon.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	icon.BackgroundTransparency = 0
	icon.ImageTransparency = 0
	icon.BorderSizePixel = 0
	icon.ZIndex = 10001
	icon.Parent = bg
	
	icon.Image = fertilizer.CustomImage({link = "https://raw.githubusercontent.com/christmas-cookie/linear/refs/heads/main/assets/image/icon.png"})

	local c2 = Instance.new("UIAspectRatioConstraint")
	c2.AspectRatio = 1
	c2.Parent = icon

	local endvid = Instance.new("VideoFrame")
	endvid.Name = "end"
	endvid.Size = UDim2.new(0.15, 0, 0.15, 0)
	endvid.Position = UDim2.new(0.5, 0, 0.5, 0)
	endvid.AnchorPoint = Vector2.new(0.5, 0.5)
	endvid.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	endvid.BackgroundTransparency = 0
	endvid.BorderSizePixel = 0
	endvid.ZIndex = 10000
	endvid.Parent = bg

	local c3 = Instance.new("UIAspectRatioConstraint")
	c3.AspectRatio = 1
	c3.Parent = endvid

	startvid.Visible = true
	icon.Visible = true
	endvid.Visible = true

	fertilizer.CustomVideo({
		link = "https://raw.githubusercontent.com/christmas-cookie/linear/refs/heads/main/assets/video/intro.webm",
		path = startvid,
		looped = false,
		volume = 1
	})

	local done = false
	local conn
	conn = startvid.Ended:Connect(function()
		done = true
	end)

	while not done do
		if startvid.TimeLength > 0 and startvid.TimePosition >= (startvid.TimeLength - 0.05) then
			break
		end
		task.wait()
	end

	if conn then conn:Disconnect() end
	startvid.Visible = false
	startvid:Destroy()

	repeat task.wait() until getgenv().linearDWloaded == true

	icon.Visible = false
	endvid.TimePosition = 0
	
	fertilizer.CustomVideo({
		link = "https://raw.githubusercontent.com/christmas-cookie/linear/refs/heads/main/assets/video/outro.webm",
		path = endvid,
		looped = false,
		volume = 1
	})

	endvid.Ended:Wait()

	task.wait(0.5)

	if startvid and startvid.Parent then startvid:Destroy() end
	if icon and icon.Parent then icon:Destroy() end
	if endvid and endvid.Parent then endvid:Destroy() end

	local fadeout = ts:Create(bg, info, {BackgroundTransparency = 1})
	fadeout:Play()
	fadeout.Completed:Wait()

	gui:Destroy()
end

return intro
