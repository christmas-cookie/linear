local intro = {}
local fertilizer = loadstring(game:HttpGet("https://raw.githubusercontent.com/christmas-cookie/linear/refs/heads/main/utilities/fertilizer"))()
local tweenservice = game:GetService("TweenService")

function intro:Start()
	local gui = Instance.new("ScreenGui")
	gui.Name = "intro"
	gui.IgnoreGuiInset = true
	gui.Parent = gethui and gethui() or game:GetService("CoreGui")

	local bgframe = Instance.new("Frame")
	bgframe.Name = "bg"
	bgframe.Size = UDim2.new(1, 0, 1, 0)
	bgframe.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	bgframe.BackgroundTransparency = 1
	bgframe.BorderSizePixel = 0
	bgframe.Parent = gui

	local startvideo = Instance.new("VideoFrame")
	startvideo.Name = "start"
	startvideo.Size = UDim2.new(0.15, 0, 0.15, 0)
	startvideo.Position = UDim2.new(0.5, 0, 0.5, 0)
	startvideo.AnchorPoint = Vector2.new(0.5, 0.5)
	startvideo.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	startvideo.BorderSizePixel = 0
	startvideo.ZIndex = 3
	startvideo.Parent = bgframe

	local constraintone = Instance.new("UIAspectRatioConstraint")
	constraintone.AspectRatio = 1
	constraintone.Parent = startvideo

	local iconimage = Instance.new("ImageLabel")
	iconimage.Name = "infinite"
	iconimage.Size = UDim2.new(0.15, 0, 0.15, 0)
	iconimage.Position = UDim2.new(0.5, 0, 0.5, 0)
	iconimage.AnchorPoint = Vector2.new(0.5, 0.5)
	iconimage.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	iconimage.BorderSizePixel = 0
	iconimage.ZIndex = 2
	iconimage.Parent = bgframe

	local constrainttwo = Instance.new("UIAspectRatioConstraint")
	constrainttwo.AspectRatio = 1
	constrainttwo.Parent = iconimage

	local endvideo = Instance.new("VideoFrame")
	endvideo.Name = "end"
	endvideo.Size = UDim2.new(0.15, 0, 0.15, 0)
	endvideo.Position = UDim2.new(0.5, 0, 0.5, 0)
	endvideo.AnchorPoint = Vector2.new(0.5, 0.5)
	endvideo.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	endvideo.BorderSizePixel = 0
	endvideo.ZIndex = 1
	endvideo.Parent = bgframe

	local constraintthree = Instance.new("UIAspectRatioConstraint")
	constraintthree.AspectRatio = 1
	constraintthree.Parent = endvideo

	local fadein = tweenservice:Create(bgframe, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 0})
	fadein:Play()
	fadein.Completed:Wait()

	fertilizer.CustomVideo({
		link = "https://raw.githubusercontent.com/christmas-cookie/linear/refs/heads/main/assets/video/intro.webm",
		path = startvideo,
		looped = false,
		volume = 1
	})

	iconimage.Image = fertilizer.CustomImage({link = "https://raw.githubusercontent.com/christmas-cookie/linear/refs/heads/main/assets/image/icon.png"})

	startvideo.Visible = true
	iconimage.Visible = true
	endvideo.Visible = true

	startvideo.Ended:Wait()
	startvideo.Visible = false

	repeat task.wait() until getgenv().linearDWloaded == true

	endvideo.TimePosition = 0
	fertilizer.CustomVideo({
		link = "https://raw.githubusercontent.com/christmas-cookie/linear/refs/heads/main/assets/video/outro.webm",
		path = endvideo,
		looped = false,
		volume = 1
	})

	local starttime = tick()
	repeat
		task.wait()
	until endvideo.TimePosition > 0 or (tick() - starttime) > 0.5

	task.wait(0.2)

	local fadeout = tweenservice:Create(bgframe, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {BackgroundTransparency = 1})
	fadeout:Play()

	iconimage.Visible = false
	endvideo.Ended:Wait()
	endvideo.Visible = false

	gui:Destroy()
end

return intro
